{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs Next.js ESLint on any TypeScript or TSX file when saved, catching errors immediately during development",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint"
  }
}